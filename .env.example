# Copy to .env and set values

# MongoDB connection string (optional). If not set, server falls back to local JSON files
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=mouthtalk

# Server port
PORT=5000

# JWT secret for session tokens (REQUIRED — server will not start without this)
JWT_SECRET=your_random_secret_here

# Firebase Admin SDK — provide ONE of these options:
# Option 1: Full JSON as env var (recommended for deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option 2: Individual fields
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Option 3: File path (for local development)
FIREBASE_SERVICE_ACCOUNT_PATH=backend/config/firebase-service-account.json

# CORS — comma-separated list of allowed origins (in addition to localhost)
ALLOWED_ORIGINS=https://your-production-domain.com

# Admin — comma-separated list of admin emails
ADMIN_EMAILS=ramaiah5496@gmail.com

# Web Push — VAPID keys (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
